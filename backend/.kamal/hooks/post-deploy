#!/bin/bash
# =============================================================================
# Post-Deploy Hook - Runs after successful deployment
# =============================================================================
# Actions:
#   1. Run smoke test against live endpoints
#   2. Verify database migrations applied
#   3. Send deployment success notification
# =============================================================================

set -e

echo "=> Post-deploy actions for Shiojiri Rainbow Seeker"

# Get deployment info
VERSION=${KAMAL_VERSION:-"unknown"}
HOSTS=${KAMAL_HOSTS:-"unknown"}
ROLE=${KAMAL_ROLE:-"unknown"}
HOST_URL=${HOST:-"api.shiojiri-rainbow.app"}

echo "   Successfully deployed version: $VERSION"
echo "   Role: $ROLE"
echo "   Hosts: $HOSTS"

# Run smoke tests (web role only)
SMOKE_TEST_PASSED=true
if [ "$ROLE" = "web" ]; then
    echo "=> Running post-deployment smoke tests..."

    # Test 1: Health check endpoint
    echo -n "   Health check (/up)... "
    HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" "https://${HOST_URL}/up" 2>/dev/null || echo "000")
    if [ "$HTTP_STATUS" = "200" ]; then
        echo "OK (${HTTP_STATUS})"
    else
        echo "FAILED (${HTTP_STATUS})"
        SMOKE_TEST_PASSED=false
    fi

    # Test 2: Readiness probe
    echo -n "   Readiness probe (/api/v1/health/ready)... "
    HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" "https://${HOST_URL}/api/v1/health/ready" 2>/dev/null || echo "000")
    if [ "$HTTP_STATUS" = "200" ]; then
        echo "OK (${HTTP_STATUS})"
    else
        echo "FAILED (${HTTP_STATUS})"
        SMOKE_TEST_PASSED=false
    fi

    # Test 3: Liveness probe
    echo -n "   Liveness probe (/api/v1/health/live)... "
    HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" "https://${HOST_URL}/api/v1/health/live" 2>/dev/null || echo "000")
    if [ "$HTTP_STATUS" = "200" ]; then
        echo "OK (${HTTP_STATUS})"
    else
        echo "FAILED (${HTTP_STATUS})"
        SMOKE_TEST_PASSED=false
    fi

    # Test 4: API response format (unauthenticated endpoint should return JSON)
    echo -n "   API format check (/api/v1/health/live)... "
    CONTENT_TYPE=$(curl -s -H "Accept: application/json" -o /dev/null -w "%{content_type}" "https://${HOST_URL}/api/v1/health/live" 2>/dev/null || echo "")
    if echo "$CONTENT_TYPE" | grep -q "json"; then
        echo "OK (JSON)"
    else
        echo "WARNING (Content-Type: ${CONTENT_TYPE})"
    fi

    if [ "$SMOKE_TEST_PASSED" = true ]; then
        echo "=> All smoke tests passed!"
    else
        echo "=> WARNING: Some smoke tests failed! Check logs for details."
    fi
fi

# Send deployment success notification (Slack)
if [ -n "$SLACK_WEBHOOK_URL" ]; then
    if [ "$SMOKE_TEST_PASSED" = true ]; then
        EMOJI="rainbow"
        STATUS="deployed successfully"
    else
        EMOJI="warning"
        STATUS="deployed with warnings"
    fi

    curl -s -X POST -H 'Content-type: application/json' \
        --data "{\"text\":\":${EMOJI}: Shiojiri Rainbow Seeker v${VERSION} ${STATUS} to ${ROLE}\"}" \
        "$SLACK_WEBHOOK_URL" 2>/dev/null || true
fi

echo "=> Deployment complete!"
echo ""
echo "   API endpoint: https://${HOST_URL}"
echo "   Health check: https://${HOST_URL}/api/v1/health/ready"
echo ""
